<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title><%= content_for(:title) || "BJJ Admin Core" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="BJJ Admin">
    <meta name="theme-color" content="#4f46e5">
    <link rel="manifest" href="/manifest.json">
    <link rel="apple-touch-icon" href="/icons/icon-192x192.png">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 font-sans text-gray-900">
    <% if user_signed_in? %>
      <div class="flex h-screen overflow-hidden" data-controller="sidebar">

        <%# Mobile overlay %>
        <div data-sidebar-target="overlay"
             data-action="click->sidebar#close"
             class="hidden fixed inset-0 z-40 bg-black/50 lg:hidden"></div>

        <%# Sidebar — drawer on mobile, static on desktop %>
        <aside data-sidebar-target="panel"
               class="fixed inset-y-0 left-0 z-50 w-64 bg-gray-900 text-white flex flex-col
                      -translate-x-full transition-transform duration-300 ease-in-out
                      lg:relative lg:translate-x-0 lg:flex-shrink-0">
          <div class="px-6 py-5 border-b border-gray-700 flex items-center justify-between">
            <div>
              <h1 class="text-lg font-bold tracking-tight">BJJ Admin</h1>
              <p class="text-xs text-gray-400 mt-0.5"><%= current_academy.name %></p>
            </div>
            <%# Close button — mobile only %>
            <button data-action="sidebar#close"
                    class="lg:hidden p-1.5 rounded-md text-gray-400 hover:text-white hover:bg-gray-700 transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>

          <nav class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto">
            <%= nav_link "Dashboard", root_path do %>
              <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
              <span>Dashboard</span>
            <% end %>
            <%= nav_link "Alunos", students_path do %>
              <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <span>Alunos</span>
            <% end %>
            <% if current_user.owner? %>
            <%= nav_link "Planos", plans_path do %>
              <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
              <span>Planos</span>
            <% end %>
            <%= nav_link "Matrículas", enrollments_path do %>
              <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
              <span>Matrículas</span>
            <% end %>
            <%= nav_link "Pagamentos", payments_path do %>
              <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
              <span>Pagamentos</span>
            <% end %>
            <% end %>
            <% if current_user.owner? %>
              <%= nav_link "Usuários", users_path do %>
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                <span>Usuários</span>
              <% end %>
              <%= nav_link "Configurações", edit_academy_path do %>
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <span>Configurações</span>
              <% end %>
            <% end %>
          </nav>

          <div class="px-4 py-4 border-t border-gray-700">
            <p class="text-xs text-gray-400 truncate"><%= current_user.email %></p>
            <p class="text-xs text-indigo-400 capitalize"><%= current_user.owner? ? "Dono" : "Professor" %></p>
            <%= button_to "Sair", destroy_user_session_path, method: :delete,
                  class: "mt-2 text-xs text-gray-400 hover:text-white transition-colors" %>
          </div>
        </aside>

        <%# Main content %>
        <div class="flex-1 flex flex-col min-w-0 overflow-hidden">

          <%# Mobile top bar %>
          <header class="lg:hidden flex items-center gap-3 px-4 py-3 bg-gray-900 text-white flex-shrink-0 border-b border-gray-700">
            <button data-action="sidebar#open"
                    class="p-1.5 rounded-md text-gray-400 hover:text-white hover:bg-gray-700 transition-colors">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
              </svg>
            </button>
            <span class="flex-1 text-sm font-bold tracking-tight">BJJ Admin</span>
            <%= button_to "Sair", destroy_user_session_path, method: :delete,
                  class: "text-xs text-gray-400 hover:text-white transition-colors px-2 py-1" %>
          </header>

          <%# Flash messages %>
          <div id="flash" class="px-4 pt-4 space-y-2 lg:px-6">
            <% flash.each do |type, message| %>
              <div data-controller="alert"
                   class="<%= flash_class(type) %> px-4 py-3 rounded-lg flex items-center justify-between">
                <span><%= message %></span>
                <button data-action="alert#dismiss" class="ml-4 text-current opacity-60 hover:opacity-100">✕</button>
              </div>
            <% end %>
          </div>

          <main class="flex-1 overflow-y-auto px-4 py-4 lg:px-6 lg:py-6">
            <%= yield %>
          </main>
        </div>
      </div>
    <% else %>
      <div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 px-4">
        <div class="w-full max-w-md">
          <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-indigo-600 rounded-2xl mb-4 shadow-lg">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
              </svg>
            </div>
            <h1 class="text-2xl font-bold text-white tracking-tight">BJJ Admin</h1>
            <p class="text-gray-400 text-sm mt-1">Gestão para academias de jiu-jitsu</p>
          </div>

          <div id="flash" class="mb-4 space-y-2">
            <% flash.each do |type, message| %>
              <div data-controller="alert"
                   class="<%= flash_class(type) %> px-4 py-3 rounded-lg flex items-center justify-between text-sm">
                <span><%= message %></span>
                <button data-action="alert#dismiss" class="ml-4 opacity-60 hover:opacity-100">✕</button>
              </div>
            <% end %>
          </div>

          <%= yield %>
        </div>
      </div>
    <% end %>
  </body>
</html>
