<% content_for :title, "Dashboard — BJJ Admin Core" %>

<div class="space-y-6">
  <h2 class="text-2xl font-bold text-gray-900">Dashboard</h2>

  <%# KPI Cards %>
  <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 <%= current_user.owner? ? "lg:grid-cols-4" : "lg:grid-cols-2" %>">
    <%= render "dashboard/kpi_card",
         label: "Alunos Ativos",
         value: @students_count,
         color: "blue" %>

    <%= render "dashboard/kpi_card",
         label: "Alunos em Risco",
         value: @risk_students.count,
         color: "yellow" %>

    <% if current_user.owner? %>
      <%= render "dashboard/kpi_card",
           label: "Inadimplentes",
           value: @overdue_count,
           color: "red" %>

      <%= render "dashboard/kpi_card",
           label: "Receita do Mês",
           value: currency(@revenue_month),
           color: "green" %>
    <% end %>
  </div>

  <%# Quick actions %>
  <div class="flex gap-3 flex-wrap">
    <% if policy(Student.new(academy: current_academy)).create? %>
      <%= link_to "Novo Aluno", new_student_path, class: "btn-primary" %>
    <% end %>
    <% if current_user.owner? %>
      <%= link_to "Nova Matrícula", new_enrollment_path, class: "btn-secondary" %>
      <%= link_to "Ver Inadimplência", payments_path, class: "btn-secondary" %>
    <% end %>
  </div>

  <%# Risk students %>
  <% if @risk_students.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <h3 class="text-sm font-semibold text-red-800 mb-3">⚠️ Alunos com atenção médica</h3>
      <ul class="space-y-1">
        <% @risk_students.each do |student| %>
          <li class="flex items-center justify-between text-sm">
            <span class="text-red-700"><%= student.name %></span>
            <%= link_to "Ver ficha", student_health_record_path(student),
                  class: "text-red-600 hover:text-red-800 font-medium" %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
</div>
