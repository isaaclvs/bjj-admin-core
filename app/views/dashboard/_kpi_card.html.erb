<% accent = {
  "blue"   => { bar: "bg-blue-500",   icon_bg: "bg-blue-50",   icon_text: "text-blue-600" },
  "red"    => { bar: "bg-red-500",    icon_bg: "bg-red-50",    icon_text: "text-red-600" },
  "green"  => { bar: "bg-emerald-500",icon_bg: "bg-emerald-50",icon_text: "text-emerald-600" },
  "yellow" => { bar: "bg-amber-400",  icon_bg: "bg-amber-50",  icon_text: "text-amber-600" }
}.fetch(color, { bar: "bg-gray-400", icon_bg: "bg-gray-50", icon_text: "text-gray-600" }) %>

<div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
  <div class="<%= accent[:bar] %> h-1 w-full"></div>
  <div class="p-5">
    <p class="text-sm font-medium text-gray-500 truncate"><%= label %></p>
    <p class="mt-2 text-3xl font-bold text-gray-900 tracking-tight"><%= value %></p>
  </div>
</div>
