<% content_for :title, "Inscrição — #{@academy.name}" %>

<div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-6">
  <%= form_with url: public_academy_slug_path(@academy.slug), method: :post, class: "space-y-6" do |f| %>
    <% if @student.errors.any? || @health_record.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-lg p-4 text-sm text-red-800">
        <p class="font-semibold mb-1">Por favor, corrija os erros abaixo:</p>
        <ul class="list-disc list-inside space-y-1">
          <% @student.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
          <% @health_record.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <h2 class="text-lg font-semibold text-gray-900 border-b border-gray-200 pb-3">Dados Pessoais</h2>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div class="sm:col-span-2">
        <%= label_tag "student[name]", "Nome completo *", class: "form-label" %>
        <%= text_field_tag "student[name]", @student.name, class: "form-input", required: true %>
      </div>
      <div>
        <%= label_tag "student[cpf]", "CPF", class: "form-label" %>
        <%= text_field_tag "student[cpf]", @student.cpf, class: "form-input" %>
      </div>
      <div>
        <%= label_tag "student[birth_date]", "Data de Nascimento", class: "form-label" %>
        <%= date_field_tag "student[birth_date]", @student.birth_date, class: "form-input" %>
      </div>
      <div>
        <%= label_tag "student[phone]", "Telefone", class: "form-label" %>
        <%= phone_field_tag "student[phone]", @student.phone, class: "form-input" %>
      </div>
      <div>
        <%= label_tag "student[email]", "Email", class: "form-label" %>
        <%= email_field_tag "student[email]", @student.email, class: "form-input" %>
      </div>
      <div>
        <%= label_tag "student[emergency_contact_name]", "Contato de Emergência", class: "form-label" %>
        <%= text_field_tag "student[emergency_contact_name]", @student.emergency_contact_name, class: "form-input" %>
      </div>
      <div>
        <%= label_tag "student[emergency_contact_phone]", "Telefone de Emergência", class: "form-label" %>
        <%= phone_field_tag "student[emergency_contact_phone]", @student.emergency_contact_phone, class: "form-input" %>
      </div>
    </div>

    <h2 class="text-lg font-semibold text-gray-900 border-b border-gray-200 pb-3 pt-2">Saúde</h2>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div>
        <%= label_tag "health_record[blood_type]", "Tipo Sanguíneo", class: "form-label" %>
        <%= select_tag "health_record[blood_type]",
              options_for_select(%w[A+ A- B+ B- AB+ AB- O+ O-], @health_record.blood_type),
              prompt: "Selecione", class: "form-input" %>
      </div>
      <div class="flex items-center gap-2 pt-6">
        <%= check_box_tag "health_record[uses_medication]", "1", @health_record.uses_medication?, class: "w-4 h-4" %>
        <%= label_tag "health_record[uses_medication]", "Usa medicação contínua", class: "text-sm text-gray-700" %>
      </div>
      <div class="sm:col-span-2">
        <%= label_tag "health_record[medication_notes]", "Quais medicações?", class: "form-label" %>
        <%= text_area_tag "health_record[medication_notes]", @health_record.medication_notes, rows: 2, class: "form-input" %>
      </div>
      <div class="sm:col-span-2">
        <%= label_tag "health_record[comorbidities][]", "Comorbidades (uma por linha)", class: "form-label" %>
        <%= text_area_tag "health_record[comorbidities][]",
              Array(@health_record.comorbidities).join("\n"),
              rows: 3, class: "form-input" %>
      </div>
      <div class="sm:col-span-2">
        <%= label_tag "health_record[allergies][]", "Alergias (uma por linha)", class: "form-label" %>
        <%= text_area_tag "health_record[allergies][]",
              Array(@health_record.allergies).join("\n"),
              rows: 2, class: "form-input" %>
      </div>
      <div class="sm:col-span-2">
        <%= label_tag "health_record[injuries][]", "Lesões/Cirurgias (uma por linha)", class: "form-label" %>
        <%= text_area_tag "health_record[injuries][]",
              Array(@health_record.injuries).join("\n"),
              rows: 2, class: "form-input" %>
      </div>
    </div>

    <%# Assinatura digital %>
    <div data-controller="signature" class="space-y-2">
      <p class="form-label">Assinatura Digital *</p>
      <canvas data-signature-target="canvas"
              width="500" height="150"
              class="border border-gray-300 rounded-lg cursor-crosshair bg-white w-full"
              data-action="mousedown->signature#startDrawing mousemove->signature#draw mouseup->signature#stopDrawing mouseleave->signature#stopDrawing touchstart->signature#startDrawing touchmove->signature#draw touchend->signature#stopDrawing">
      </canvas>
      <button type="button" data-action="signature#clear"
              class="text-xs text-gray-500 hover:text-gray-700">Limpar assinatura</button>
      <%= hidden_field_tag "health_record[signature_data]", "", data: { signature_target: "input" } %>
      <%= hidden_field_tag "health_record[signed_at]", Time.current %>
    </div>

    <%# LGPD Consent %>
    <div class="bg-gray-50 border border-gray-200 rounded-lg p-4 space-y-2">
      <p class="text-sm font-medium text-gray-900">Consentimento LGPD *</p>
      <p class="text-xs text-gray-600">
        Ao marcar esta opção, você consente com o armazenamento dos seus dados pessoais
        e de saúde pela academia, conforme a Lei Geral de Proteção de Dados (LGPD).
      </p>
      <label class="flex items-center gap-2 text-sm text-gray-700">
        <%= check_box_tag "health_record[lgpd_consent]", "1", @health_record.lgpd_consent?, class: "w-4 h-4 text-indigo-600" %>
        Li e aceito os termos de uso e política de privacidade
      </label>
    </div>

    <button type="submit" class="w-full btn-primary text-center py-3 text-base">
      Enviar Inscrição
    </button>
  <% end %>
</div>
