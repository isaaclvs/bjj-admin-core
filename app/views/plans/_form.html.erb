<%= form_with model: plan, class: "space-y-5" do |f| %>
  <%= render "shared/errors", object: plan %>

  <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
    <div class="sm:col-span-2">
      <%= f.label :name, "Nome do plano", class: "form-label" %>
      <%= f.text_field :name, class: "form-input", required: true %>
    </div>

    <div>
      <%= f.label :price_cents, "Valor (em centavos)", class: "form-label" %>
      <%= f.number_field :price_cents, class: "form-input", min: 1, required: true %>
      <p class="mt-1 text-xs text-gray-500">Ex: 15000 = R$ 150,00</p>
    </div>

    <div>
      <%= f.label :interval, "Periodicidade", class: "form-label" %>
      <%= f.select :interval,
            Plan.intervals.keys.map { |i| [t("enums.plan.interval.#{i}"), i] },
            {}, class: "form-input" %>
    </div>

    <div class="sm:col-span-2">
      <%= f.label :description, "Descrição", class: "form-label" %>
      <%= f.text_area :description, rows: 3, class: "form-input" %>
    </div>

    <div class="flex items-center gap-2">
      <%= f.check_box :active, class: "w-4 h-4 text-indigo-600" %>
      <%= f.label :active, "Plano ativo", class: "text-sm text-gray-700" %>
    </div>
  </div>

  <div class="flex items-center gap-3 pt-2">
    <%= f.submit class: "btn-primary cursor-pointer" %>
    <%= link_to "Cancelar", plans_path, class: "btn-secondary" %>
  </div>
<% end %>
