<div id="<%= dom_id(plan) %>" class="bg-white rounded-xl border border-gray-200 shadow-sm p-5 space-y-3">
  <div class="flex items-start justify-between">
    <div>
      <h3 class="font-semibold text-gray-900"><%= plan.name %></h3>
      <p class="text-sm text-gray-500"><%= t("enums.plan.interval.#{plan.interval}") %></p>
    </div>
    <% unless plan.active? %>
      <span class="text-xs px-2 py-0.5 rounded bg-gray-100 text-gray-500">Inativo</span>
    <% end %>
  </div>

  <p class="text-2xl font-bold text-indigo-600"><%= currency(plan.price) %></p>

  <% if plan.description.present? %>
    <p class="text-sm text-gray-600"><%= plan.description %></p>
  <% end %>

  <div class="flex gap-3 text-sm pt-1">
    <%= link_to "Editar", edit_plan_path(plan), class: "text-indigo-600 hover:underline" %>
    <%= button_to "Remover", plan, method: :delete,
          data: { turbo_confirm: "Remover o plano #{plan.name}?" },
          class: "text-red-600 hover:underline bg-transparent border-none p-0 cursor-pointer" %>
  </div>
</div>
