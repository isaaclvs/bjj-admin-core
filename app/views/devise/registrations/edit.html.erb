<div class="bg-white rounded-2xl shadow-xl p-8">
  <h2 class="text-xl font-bold text-gray-900 mb-6">Minha Conta</h2>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="space-y-5">
      <div>
        <%= f.label :email, "E-mail", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "w-full px-4 py-2.5 rounded-lg border border-gray-300 text-sm bg-gray-50
                      focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500
                      focus:border-transparent transition" %>
        <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
          <p class="mt-1 text-xs text-amber-600">Aguardando confirmação para: <%= resource.unconfirmed_email %></p>
        <% end %>
      </div>

      <div>
        <%= f.label :password, "Nova senha", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <p class="text-xs text-gray-500 mb-1.5">Deixe em branco para manter a senha atual<% if @minimum_password_length %> · mínimo <%= @minimum_password_length %> caracteres<% end %></p>
        <div class="relative" data-controller="password-visibility">
          <%= f.password_field :password, autocomplete: "new-password", placeholder: "••••••••",
                data: { "password-visibility-target": "input" },
                class: "w-full px-4 py-2.5 pr-11 rounded-lg border border-gray-300 text-sm bg-gray-50
                        focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500
                        focus:border-transparent transition" %>
          <button type="button" data-action="password-visibility#toggle"
                  class="absolute inset-y-0 right-0 flex items-center px-3 text-gray-400 hover:text-gray-600">
            <svg data-password-visibility-target="showIcon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
            <svg data-password-visibility-target="hideIcon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>
          </button>
        </div>
      </div>

      <div>
        <%= f.label :password_confirmation, "Confirmar nova senha", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "••••••••",
              class: "w-full px-4 py-2.5 rounded-lg border border-gray-300 text-sm bg-gray-50
                      focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500
                      focus:border-transparent transition" %>
      </div>

      <div class="border-t border-gray-200 pt-5">
        <%= f.label :current_password, "Senha atual", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <p class="text-xs text-gray-500 mb-1.5">Necessária para confirmar as alterações</p>
        <div class="relative" data-controller="password-visibility">
          <%= f.password_field :current_password, autocomplete: "current-password", placeholder: "••••••••",
                data: { "password-visibility-target": "input" },
                class: "w-full px-4 py-2.5 pr-11 rounded-lg border border-gray-300 text-sm bg-gray-50
                        focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500
                        focus:border-transparent transition" %>
          <button type="button" data-action="password-visibility#toggle"
                  class="absolute inset-y-0 right-0 flex items-center px-3 text-gray-400 hover:text-gray-600">
            <svg data-password-visibility-target="showIcon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
            <svg data-password-visibility-target="hideIcon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>
          </button>
        </div>
      </div>

      <%= f.submit "Salvar alterações",
            class: "w-full py-2.5 px-4 bg-indigo-600 hover:bg-indigo-700 text-white text-sm
                    font-semibold rounded-lg shadow-sm focus:outline-none focus:ring-2
                    focus:ring-indigo-500 focus:ring-offset-2 transition-colors cursor-pointer" %>
    </div>
  <% end %>

  <div class="mt-6 pt-5 border-t border-gray-200">
    <p class="text-sm font-medium text-gray-700 mb-2">Cancelar conta</p>
    <p class="text-xs text-gray-500 mb-3">Esta ação é irreversível. Todos os seus dados serão removidos.</p>
    <%= button_to "Encerrar minha conta", registration_path(resource_name),
          data: { turbo_confirm: "Tem certeza? Esta ação não pode ser desfeita." },
          method: :delete,
          class: "text-sm text-red-600 hover:text-red-800 font-medium transition-colors" %>
  </div>
</div>
