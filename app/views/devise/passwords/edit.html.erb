<div class="bg-white rounded-2xl shadow-xl p-8">
  <div class="mb-6">
    <h2 class="text-xl font-bold text-gray-900">Criar nova senha</h2>
    <% if @minimum_password_length %>
      <p class="text-sm text-gray-500 mt-1">Mínimo de <%= @minimum_password_length %> caracteres.</p>
    <% end %>
  </div>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>
    <%= f.hidden_field :reset_password_token %>

    <div class="space-y-5">
      <div>
        <%= f.label :password, "Nova senha", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <div class="relative" data-controller="password-visibility">
          <%= f.password_field :password,
                autofocus: true,
                autocomplete: "new-password",
                placeholder: "••••••••",
                data: { "password-visibility-target": "input" },
                class: "w-full px-4 py-2.5 pr-11 rounded-lg border border-gray-300 text-sm text-gray-900
                        placeholder-gray-400 bg-gray-50 focus:bg-white focus:outline-none
                        focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" %>
          <button type="button"
                  data-action="password-visibility#toggle"
                  class="absolute inset-y-0 right-0 flex items-center px-3 text-gray-400 hover:text-gray-600">
            <svg data-password-visibility-target="showIcon"
                 class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7
                       -1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
            </svg>
            <svg data-password-visibility-target="hideIcon"
                 class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7
                       a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243
                       M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29
                       M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7
                       a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>
            </svg>
          </button>
        </div>
      </div>

      <div>
        <%= f.label :password_confirmation, "Confirmar nova senha",
              class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <div class="relative" data-controller="password-visibility">
          <%= f.password_field :password_confirmation,
                autocomplete: "new-password",
                placeholder: "••••••••",
                data: { "password-visibility-target": "input" },
                class: "w-full px-4 py-2.5 pr-11 rounded-lg border border-gray-300 text-sm text-gray-900
                        placeholder-gray-400 bg-gray-50 focus:bg-white focus:outline-none
                        focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" %>
          <button type="button"
                  data-action="password-visibility#toggle"
                  class="absolute inset-y-0 right-0 flex items-center px-3 text-gray-400 hover:text-gray-600">
            <svg data-password-visibility-target="showIcon"
                 class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7
                       -1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
            </svg>
            <svg data-password-visibility-target="hideIcon"
                 class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7
                       a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243
                       M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29
                       M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7
                       a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>
            </svg>
          </button>
        </div>
      </div>

      <%= f.submit "Salvar nova senha",
            class: "w-full py-2.5 px-4 bg-indigo-600 hover:bg-indigo-700 text-white text-sm
                    font-semibold rounded-lg shadow-sm focus:outline-none focus:ring-2
                    focus:ring-indigo-500 focus:ring-offset-2 transition-colors cursor-pointer" %>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
</div>
