<%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
  <p class="text-center mt-5 text-sm text-gray-500">
    <%= link_to "Esqueceu sua senha?", new_password_path(resource_name),
                class: "text-indigo-400 hover:text-indigo-300 font-medium transition-colors" %>
  </p>
<% end %>

<%- if controller_name != 'sessions' %>
  <p class="text-center mt-4 text-sm text-gray-500">
    <%= link_to "← Voltar para o login", new_session_path(resource_name),
                class: "text-indigo-400 hover:text-indigo-300 font-medium transition-colors" %>
  </p>
<% end %>
