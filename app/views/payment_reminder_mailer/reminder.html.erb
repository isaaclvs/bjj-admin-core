<h2>Olá, <%= @student.name %>!</h2>

<p>
  Identificamos um pagamento em atraso na <strong><%= @academy.name %></strong>.
</p>

<table>
  <tr>
    <td><strong>Valor:</strong></td>
    <td>R$ <%= "%.2f" % @payment.amount %></td>
  </tr>
  <tr>
    <td><strong>Vencimento:</strong></td>
    <td><%= @payment.due_date.strftime("%d/%m/%Y") %></td>
  </tr>
</table>

<p>
  Entre em contato com a academia para regularizar sua situação e evitar a suspensão da matrícula.
</p>

<p>
  <%= @academy.name %>
</p>
